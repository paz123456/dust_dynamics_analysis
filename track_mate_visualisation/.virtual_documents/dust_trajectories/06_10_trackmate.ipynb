%load_ext autoreload
%autoreload 2


import matplotlib.pyplot as plt
import pandas as pd
from pathlib import Path
import tifffile as tiff
import numpy as np
import os
import track_mate_visualisation as tmv
import scienceplots


plt.style.use(["science", "high-vis", "bright", "no-latex"])


sorted(
    [i for i in os.listdir("/Volumes/Festplatte2/06_10_25/") if not "._" in i],
    reverse=True,
)


min_length = 70
max_sign_changes_x = 4
max_sign_changes_y = 4
min_y = 1000
min_max_y = 150

median_k = 5
hampel_w = 7
hampel_sigma = 3.0
sg_window = 11
sg_poly = 2
butter_cutoff = None

trajectory_filter_set = tmv.trajectory_filters.make_traj_filter(
    median_k=median_k,
    hampel_w=hampel_w,
    hampel_sigma=hampel_sigma,
    sg_window=sg_window,
    sg_poly=sg_poly,
    butter_cutoff=0.15,  # or None
)








path = Path("/Volumes/Festplatte2/06_10_25/lhc_beamscreen_UV_then_2kV_silica/")
p_tifs = path / "tifs"
tifs = [
    p_tifs / i
    for i in sorted(os.listdir(p_tifs))
    if ".tif" in i and not "absdiff" in i and not "._" in i
    #  and int(i.split("_")[1].replace(".tif", "")) >= 18000
]
edges = sorted(
    [
        path / "results" / i
        for i in os.listdir(path / "results")
        if "edges" in i and ".csv" in i and not "._" in i
    ],
    key=lambda s: str(s).split("_")[1],
)
spots = sorted(
    [
        path / "results" / i
        for i in os.listdir(path / "results")
        if "spots" in i and ".csv" in i and not "._" in i
    ],
    key=lambda s: str(s).split("_")[1],
)

img_id = 0
img = tiff.imread(tifs[0]).astype("float32")
out = tmv.dataprocessing.combine_csv(paths_edges=edges, paths_spots=spots)
df_spots = out["spots"]
df_edges = out["edges"]

out = tmv.dataprocessing.filter_df(
    df_spots=df_spots,
    df_edges=df_edges,
    min_y=min_y,
    max_sign_changes_x=max_sign_changes_x,
    max_sign_changes_y=max_sign_changes_y,
    min_length=min_length,
    apply_filter=trajectory_filter_set,
    min_max_y=min_max_y,
)
df_spots = out["spots"]
df_edges = out["edges"]

fig, ax = plt.subplots(figsize=(8, 4))
tmv.plot.plot(spots=df_spots, edges=df_edges, img_id=img_id, img=img, fig=fig, ax=ax)
fig.savefig("./UV_2kV_lhcbeamscreen.png", dpi=300)








